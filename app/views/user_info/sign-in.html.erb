<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bubblegum+Sans&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        helveticaNow: ['"Helvetica Now Text"', '"Helvetica Neue"', 'Helvetica', 'Arial', 'sans-serif']
                    }
                }
            }
        };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .site-nav {
            background-color: #283618;
            color: #FEFAE0;
        }

        .site-title {
            font-family: "Helvetica Now Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
            font-weight: 700;
            color: #ffffff;
        }

        body.kids-theme {
            background-color: #FF9696;
            color: #ffffff;
            font-family: "Bubblegum Sans", "Comic Sans MS", "Trebuchet MS", cursive;
        }

        body.kids-theme .site-nav {
            background-color: #600000;
        }

        body.kids-theme .site-title {
            font-family: "Helvetica Now Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
            -webkit-text-stroke: 0;
            paint-order: fill;
        }

        body.kids-theme .nav-link,
        body.kids-theme .mode-label,
        body.kids-theme .page-content :is(h1, h2, h3, p, a, li, button, span) {
            -webkit-text-stroke: 5px #000;
            paint-order: stroke fill;
            text-shadow:
                0 4px 0 rgba(0, 0, 0, 0.99),
                0 0px 34px rgba(0, 0, 0, 0.99);
        }

        body.kids-theme .nav-link,
        body.kids-theme .mode-label {
            font-size: 1.2rem;
        }

        body.kids-theme .page-content {
            font-size: 1.15rem;
            color: #ffffff;
        }

        body.kids-theme .page-content :is(p, li, a, span, button) {
            letter-spacing: 0.08em;
        }

        body.kids-theme .below-hero-copy :is(p, li, a, span, button) {
            font-size: 35px;
        }

        body.kids-theme #kids-mode .kids-hero-title,
        body.kids-theme #kids-mode .kids-heading {
            font-size: 70px;
            line-height: 1.05;
        }

        body.kids-theme #kids-mode .kids-text {
            font-size: 35px;
            line-height: 1.12;
        }

        body.kids-theme #kids-mode .hero-auth-button {
            font-family: "Helvetica Now Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
            -webkit-text-stroke: 0;
            paint-order: fill;
        }

        body.kids-theme .kids-grid-lines {
            background-color: #ff9090;
            background-image:
                linear-gradient(to right, rgba(255, 255, 255, 0.85) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255, 255, 255, 0.85) 1px, transparent 1px);
            background-size: 42px 42px;
        }

        .below-hero-copy :is(p, li, a, span, button) {
            font-family: "Sassoon Primary", "Sassoon Primary Std", "Helvetica Now Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
        }

        .content-box {
            border-radius: 1rem;
            border: 1px solid rgba(40, 54, 24, 0.2);
            background-color: rgba(255, 255, 255, 0.8);
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
            padding: 1.5rem;
        }

        .auth-card {
            width: 100%;
            max-width: 28rem;
        }

        .auth-input {
            border: 1px solid rgba(40, 54, 24, 0.3);
            background-color: #ffffff;
            color: #283618;
        }

        .auth-input::placeholder {
            color: rgba(40, 54, 24, 0.6);
        }

        .auth-error {
            border-radius: 0.75rem;
            border: 1px solid rgba(127, 29, 29, 0.35);
            background-color: rgba(254, 226, 226, 0.75);
            color: #7f1d1d;
            padding: 0.75rem 1rem;
        }

        body.kids-theme .content-box {
            border-color: rgba(255, 255, 255, 0.75);
            background-color: rgba(126, 0, 0, 0.45);
        }

        body.kids-theme .auth-card :is(h1, p, a, button, label) {
            -webkit-text-stroke: 5px #000;
            paint-order: stroke fill;
            text-shadow:
                0 4px 0 rgba(0, 0, 0, 0.99),
                0 0px 34px rgba(0, 0, 0, 0.99);
        }

        body.kids-theme .auth-card :is(p, a, button, label) {
            font-size: 1.3rem;
            line-height: 1.2;
        }

        body.kids-theme .auth-card .auth-input {
            font-size: 1.15rem;
            line-height: 1.35;
        }

        body.kids-theme .auth-input {
            border-color: rgba(255, 255, 255, 0.8);
            background-color: rgba(255, 255, 255, 0.2);
            color: #ffffff;
        }

        body.kids-theme .auth-input::placeholder {
            color: rgba(255, 255, 255, 0.8);
        }

        body.kids-theme .auth-submit {
            background-color: #FDBA74;
            color: #600000;
        }

        body.kids-theme .auth-submit:hover {
            background-color: #fb923c;
        }

        body.kids-theme .auth-alt-link {
            color: #fff9d6;
        }

        body.kids-theme .auth-error {
            border-color: rgba(255, 255, 255, 0.7);
            background-color: rgba(96, 0, 0, 0.45);
            color: #ffffff;
        }
    </style>
</head>
<body class="min-h-screen bg-[#FEFAE0] text-[#283618] font-helveticaNow font-bold">
    <nav id="site-nav" class="site-nav shadow-md">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-8">
            <div class="flex items-center gap-4 sm:gap-6">
                <a href="index.html" class="flex items-center gap-3" title="Home">
                    <img src="<%= asset_path("FoodLogo.png") %>" alt="Home" class="h-11 w-11 object-contain">
                    <span class="site-title text-lg tracking-wide sm:text-xl">NUTRIFACT</span>
                </a>
                <ul class="hidden items-center gap-4 sm:flex lg:gap-6">
                    <li><a href="all-recipies.html" class="nav-link mode-text text-base transition-opacity hover:opacity-80 sm:text-lg">Recipes</a></li>
                    <li><a href="disorders.html" class="nav-link mode-text text-base transition-opacity hover:opacity-80 sm:text-lg">Disorders</a></li>
                    <li><a href="resources.html" class="nav-link mode-text text-base transition-opacity hover:opacity-80 sm:text-lg">Resources</a></li>
                    <li><a href="about.html" class="nav-link mode-text text-base transition-opacity hover:opacity-80 sm:text-lg">About</a></li>
                </ul>
            </div>

            <div class="flex items-center gap-2 sm:gap-3">
                <span id="adult-label" class="mode-label mode-text text-xs uppercase tracking-wide opacity-100 sm:text-sm">Adult</span>
                <button
                    id="mode-toggle"
                    type="button"
                    role="switch"
                    aria-checked="false"
                    aria-label="Toggle adult mode and kids mode"
                    class="relative h-8 w-16 rounded-full border border-[#FEFAE0]/70 bg-lime-700 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[#FEFAE0] focus:ring-offset-2 focus:ring-offset-[#283618]"
                >
                    <span id="mode-toggle-thumb" class="absolute left-1 top-1 h-6 w-6 rounded-full bg-[#FEFAE0] transition-transform duration-300"></span>
                </button>
                <span id="kids-label" class="mode-label mode-text text-xs uppercase tracking-wide opacity-60 sm:text-sm">Kids</span>
            </div>
        </div>

        <div class="border-t border-[#FEFAE0]/20 px-4 pb-4 pt-3 sm:hidden">
            <ul class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
                <li><%= link_to "Recipes", "/user_info/all-recipes", class: "nav-link mode-text text-base transition-opacity hover:opacity-80" %></li>
                <li><%= link_to "Disorders", "/user_info/disorders", class: "nav-link mode-text text-base transition-opacity hover:opacity-80" %></li>
                <li><%= link_to "Resources", "/user_info/resources", class: "nav-link mode-text text-base transition-opacity hover:opacity-80" %></li>
                <li><%= link_to "About", "/user_info/about", class: "nav-link mode-text text-base transition-opacity hover:opacity-80" %></li>
            </ul>
        </div>
    </nav>

    <div id="adult-mode" class="page-content flex min-h-[calc(100vh-6.5rem)] items-center justify-center px-4 py-10 sm:px-6">
        <section class="content-box auth-card">
            <h1 class="mb-6 text-center text-3xl sm:text-4xl">Sign In</h1>

            <% if flash[:alert] %>
                <div class="auth-error mb-5 text-sm sm:text-base"><%= flash[:alert] %></div>
            <% end %>

            <%= form_with url: session_path, class: "space-y-4" do |form| %>
                <div class="space-y-2">
                    <%= form.label :email_address, class: "block text-sm font-semibold tracking-wide sm:text-base" %>
                    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params[:email_address], class: "auth-input w-full rounded-xl px-4 py-3 text-base font-semibold focus:border-lime-700 focus:outline-none focus:ring-2 focus:ring-lime-700/30" %>
                </div>

                <div class="space-y-2">
                    <%= form.label :password, class: "block text-sm font-semibold tracking-wide sm:text-base" %>
                    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "auth-input w-full rounded-xl px-4 py-3 text-base font-semibold focus:border-lime-700 focus:outline-none focus:ring-2 focus:ring-lime-700/30" %>
                </div>

                <div class="pt-2">
                    <%= form.submit "Sign in", class: "auth-submit w-full rounded-xl bg-lime-700 px-4 py-3 text-base font-bold text-[#FEFAE0] shadow-sm transition-colors hover:bg-lime-800 focus:outline-none focus:ring-2 focus:ring-lime-700/40 focus:ring-offset-2 focus:ring-offset-[#FEFAE0]" %>
                </div>

                <p class="pt-1 text-center text-sm sm:text-base">
                    <%= link_to "Create account instead?", "/user_info/create-acc", class: "auth-alt-link underline decoration-2 underline-offset-4 transition-opacity hover:opacity-80" %>
                </p>
            <% end %>
        </section>
    </div>
    <script src="/utilities.js" data-turbo-eval="true"></script>
</body>
</html>
